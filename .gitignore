context/portfolio/wave*-review-*.md

# Telemetry output (user-accumulated; generated by hooks/telemetry-extract.py)
context/roi/audit-receipts.jsonl
context/.telemetry-dedup
context/.tracker-dedup

# Stale protocol-rewrite backups (never publish)
*.pre-v5-spawn-rewrite-*

# Organizational memory is created locally on install (install.py scaffolds it).
# The repo ships NO populated context/ — only the demo fixtures used by /tour, /reset-demo, /clear-demo.
context/
!context/demo/
!context/demo/**
